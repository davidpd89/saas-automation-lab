---
import BaseLayout from './BaseLayout.astro';
import MascotImage from "../components/MascotImage.astro";
import type { CollectionEntry } from 'astro:content';

interface Props {
  frontmatter: CollectionEntry<'pillars'>['data'];
}

const { frontmatter } = Astro.props;
const siteUrl = new URL(import.meta.env.BASE_URL, Astro.site ?? new URL("https://davidpd89.github.io")).toString();

const labSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": frontmatter.title,
  "description": frontmatter.description,
  "url": new URL("lab/", siteUrl).toString(),
  "mainEntity": {
    "@type": "Organization",
    "name": "Lab de Automatizacion",
    "description": "Laboratorio de testing para herramientas SaaS e IA",
    "url": new URL("lab/", siteUrl).toString(),
    "sameAs": [
      "https://github.com/davidpd89/saas-automation-lab"
    ]
  }
};
---

<BaseLayout title={frontmatter.seoTitle} description={frontmatter.seoDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(labSchema)} />

  <div class="max-w-4xl mx-auto px-4 py-12">
    <header class="text-center mb-12">
      <div class="inline-flex items-center justify-center w-16 h-16 bg-blue-100 rounded-full mb-4">
        <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
        </svg>
      </div>
      <h1 class="text-4xl font-bold text-gray-900 mb-4">
        {frontmatter.title}
      </h1>
      <MascotImage
        type="nosotros"
        class="page-mascot"
        customAlt="David y SaaS Automation Lab documentando metodologia de pruebas E-E-A-T"
      />
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        {frontmatter.description}
      </p>
    </header>

    <main class="prose prose-lg max-w-none">
      <slot />
    </main>

    <footer class="mt-16 pt-8 border-t border-gray-200">
      <div class="text-center text-gray-500">
        <p class="mb-2">
          <strong>Ultima actualizacion:</strong> Mayo 2026
        </p>
        <p class="mb-2">
          <strong>Proxima revision:</strong> Agosto 2026
        </p>
        <div class="flex justify-center space-x-6 text-sm">
          <a href="https://github.com/davidpd89/saas-automation-lab" class="text-blue-600 hover:text-blue-700" target="_blank">
            Repositorio del lab
          </a>
        </div>
      </div>
    </footer>
  </div>
</BaseLayout>
