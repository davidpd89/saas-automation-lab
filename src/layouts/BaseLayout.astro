---
import "../styles/global.css";
import defaultOgImage from "../assets/automatiza-sin-humo-og-home.webp";
import type { ImageMetadata } from "astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: ImageMetadata | string;
}

const {
  title,
  description = "Comparativas, guías y flujos reales de automatización SaaS e IA para negocios de servicios.",
  ogImage = defaultOgImage
} = Astro.props;
const basePath = import.meta.env.BASE_URL;
const siteOrigin = Astro.site ?? new URL("https://davidpd89.github.io");
const siteUrl = new URL(basePath, siteOrigin).toString();
const currentPath = Astro.url.pathname.startsWith(basePath)
  ? Astro.url.pathname.slice(basePath.length)
  : Astro.url.pathname.replace(/^\/+/, "");
const canonicalUrl = new URL(currentPath, siteUrl).toString();
const withBase = (path = "") => `${basePath}${path.replace(/^\/+/, "")}`;
const ogImagePath = typeof ogImage === "string" ? ogImage : ogImage.src;
const ogImageUrl = new URL(ogImagePath, siteUrl).toString();
const breadcrumbParts = currentPath.split("/").filter(Boolean);
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Inicio", item: siteUrl },
    ...breadcrumbParts.map((part, index) => ({
      "@type": "ListItem",
      position: index + 2,
      name: part.replace(/-/g, " "),
      item: new URL(`${breadcrumbParts.slice(0, index + 1).join("/")}/`, siteUrl).toString()
    }))
  ]
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Automatiza Sin Humo" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      name: "Automatiza Sin Humo",
      url: siteUrl,
      description: "Comparativas, guías y flujos reales de automatización SaaS e IA para negocios de servicios.",
      sameAs: ["https://github.com/davidpd89/saas-automation-lab"]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </head>
  <body data-base-url={basePath}>
    <header>
      <div class="container">
        <nav aria-label="Principal">
          <a href={withBase()}>Inicio</a>
          <a href={withBase("herramientas/")}>Herramientas</a>
          <a href={withBase("comparativas/")}>Comparativas</a>
          <a href={withBase("guias/")}>Guías</a>
          <a href={withBase("automatizacion-solopreneurs-2026/")}>Pilar</a>
          <a href={withBase("lab/")}>Lab</a>
          <a href={withBase("como-probamos/")}>Cómo probamos</a>
          <a href={withBase("legal/")}>Legal</a>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer>
      <div class="container">
        <small>Automatiza Sin Humo. Comparativas, guías y flujos reales de automatización SaaS e IA. Algunos enlaces pueden ser afiliados. <a href={withBase("criterios-evaluacion/")}>Criterios editoriales</a>.</small>
      </div>
    </footer>
    <script>
      window.addEventListener("affiliate-click", (event) => {
        const detail = event.detail || {};
        const key = "affiliate_click_log";
        const previous = JSON.parse(localStorage.getItem(key) || "[]");
        previous.push(detail);
        localStorage.setItem(key, JSON.stringify(previous.slice(-100)));
      });
    </script>
  </body>
</html>
