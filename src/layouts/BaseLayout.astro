---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Web de afiliación SaaS e IA para solopreneurs." } = Astro.props;
const basePath = import.meta.env.BASE_URL;
const siteOrigin = Astro.site ?? new URL("https://davidpd89.github.io");
const siteUrl = new URL(basePath, siteOrigin).toString();
const currentPath = Astro.url.pathname.startsWith(basePath)
  ? Astro.url.pathname.slice(basePath.length)
  : Astro.url.pathname.replace(/^\/+/, "");
const canonicalUrl = new URL(currentPath, siteUrl).toString();
const withBase = (path = "") => `${basePath}${path.replace(/^\/+/, "")}`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      name: "Temp SaaS IA Affiliate Lab",
      url: siteUrl,
      description
    })} />
  </head>
  <body>
    <header>
      <div class="container">
        <nav aria-label="Principal">
          <a href={withBase()}>Inicio</a>
          <a href={withBase("herramientas/n8n-cloud/")}>Herramientas</a>
          <a href={withBase("comparativas/n8n-vs-make-vs-zapier/")}>Comparativas</a>
          <a href={withBase("guias/onboarding-automatizado-n8n-whatsapp/")}>Guias</a>
          <a href={withBase("automatizacion-solopreneurs-2026/")}>Pilar</a>
          <a href={withBase("lab/")}>Lab</a>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer>
      <div class="container">
        <small>Proyecto base de afiliación SaaS/IA en Astro.</small>
      </div>
    </footer>
    <script>
      window.addEventListener("affiliate-click", (event) => {
        const detail = event.detail || {};
        const key = "affiliate_click_log";
        const previous = JSON.parse(localStorage.getItem(key) || "[]");
        previous.push(detail);
        localStorage.setItem(key, JSON.stringify(previous.slice(-100)));
      });
    </script>
  </body>
</html>
