---
import { Image } from "astro:assets";
import homeImage from "../assets/automatiza-sin-humo-hero-automatizacion-saas-ia.webp";
import comparativasImage from "../assets/automatiza-sin-humo-comparativa-n8n-make-zapier.webp";
import guiasImage from "../assets/automatiza-sin-humo-guia-onboarding-automatizado-clientes.webp";
import herramientasImage from "../assets/automatiza-sin-humo-herramientas-saas-automatizacion.webp";
import labImage from "../assets/automatiza-sin-humo-lab-metodologia-workflows.webp";
import stackImage from "../assets/automatiza-sin-humo-mapa-stack-automatizacion-negocio.webp";
import legalImage from "../assets/automatiza-sin-humo-transparencia-editorial-afiliados.webp";
import consultorImage from "../assets/automatiza-sin-humo-consultor-b2b-prospeccion-crm.webp";
import formadorImage from "../assets/automatiza-sin-humo-formador-cursos-email-automatizado.webp";
import coachImage from "../assets/automatiza-sin-humo-coach-onboarding-seguimiento.webp";

const visualMap = {
  home: {
    src: homeImage,
    defaultAlt: "Sistema visual de automatizacion SaaS e IA para negocios de servicios sin caos"
  },
  comparativas: {
    src: comparativasImage,
    defaultAlt: "Comparativa visual n8n Make y Zapier para automatizacion SaaS en 2026"
  },
  guias: {
    src: guiasImage,
    defaultAlt: "Guia de onboarding automatizado para clientes con flujos SaaS e IA"
  },
  herramientas: {
    src: herramientasImage,
    defaultAlt: "Mapa visual de herramientas SaaS para automatizar procesos de negocio"
  },
  nosotros: {
    src: labImage,
    defaultAlt: "Metodologia del laboratorio para probar workflows reales de automatizacion"
  },
  resultados: {
    src: stackImage,
    defaultAlt: "Mapa de stack de automatizacion para escalar un negocio de servicios con IA"
  },
  legal: {
    src: legalImage,
    defaultAlt: "Transparencia editorial y criterios de afiliacion para recomendaciones SaaS"
  },
  consultor: {
    src: consultorImage,
    defaultAlt: "Consultor B2B organizando prospeccion CRM y automatizaciones de seguimiento"
  },
  formador: {
    src: formadorImage,
    defaultAlt: "Formador conectando cursos email marketing y automatizacion evergreen"
  },
  coach: {
    src: coachImage,
    defaultAlt: "Coach automatizando onboarding seguimiento y experiencia de cliente"
  }
};

interface Props {
  type: keyof typeof visualMap;
  customAlt?: string;
  class?: string;
  loading?: "lazy" | "eager";
  priority?: boolean;
  width?: number;
}

const {
  type,
  customAlt,
  class: className = "",
  loading = "lazy",
  priority = false,
  width
} = Astro.props;
const visual = visualMap[type];
const displayWidth = width ?? (type === "home" ? 560 : 720);
const sizes =
  type === "home"
    ? "(max-width: 760px) 92vw, 520px"
    : "(max-width: 920px) 92vw, 720px";
---

<figure class={`mascot-container ${className}`}>
  <Image
    src={visual.src}
    alt={customAlt ?? visual.defaultAlt}
    format="avif"
    quality={76}
    width={displayWidth}
    sizes={sizes}
    loading={loading}
    decoding="async"
    fetchpriority={priority ? "high" : "auto"}
    class="mascot-img"
  />
  <figcaption class="sr-only">Imagen editorial de Automatiza Sin Humo con estética de laboratorio, negocio y workflows reales.</figcaption>
</figure>
