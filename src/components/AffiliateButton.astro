---
interface Props {
  url: string;
  label: string;
  toolId: string;
  variant?: 'primary' | 'secondary' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  showDisclosure?: boolean;
}

const { 
  url, 
  label, 
  toolId, 
  variant = 'primary', 
  size = 'md',
  showDisclosure = true 
} = Astro.props;

// Base classes for different variants
const baseClasses = "inline-flex items-center justify-center rounded-lg font-medium transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-offset-2";

const variantClasses = {
  primary: "bg-blue-600 text-white hover:bg-blue-700 focus:ring-blue-500",
  secondary: "bg-gray-600 text-white hover:bg-gray-700 focus:ring-gray-500", 
  outline: "border-2 border-blue-600 text-blue-600 hover:bg-blue-50 focus:ring-blue-500"
};

const sizeClasses = {
  sm: "px-3 py-1.5 text-sm",
  md: "px-4 py-2 text-base",
  lg: "px-6 py-3 text-lg"
};

const classes = `${baseClasses} ${variantClasses[variant]} ${sizeClasses[size]}`;
---

{showDisclosure && (
  <div class="mb-2 text-xs text-gray-500 flex items-center">
    <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
      <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
    </svg>
    Enlace de afiliado: podemos ganar una comisión si te registras
  </div>
)}

<a 
  href={url}
  class={classes}
  rel="sponsored nofollow"
  target="_blank"
  aria-label={`Abrir ${label} en pestaña nueva`}
  data-tool-id={toolId}
  data-affiliate-tracker="true"
  onClick={() => {
    // Track affiliate click
    if (typeof window !== 'undefined' && window.gtag) {
      window.gtag('event', 'affiliate_click', {
        tool_id: toolId,
        button_label: label,
        button_variant: variant,
        page_location: window.location.pathname
      });
    }
    
    // Track with Plausible if available
    if (typeof window !== 'undefined' && window.plausible) {
      window.plausible('Affiliate Click', {
        props: {
          tool: toolId,
          variant: variant,
          label: label
        }
      });
    }
  }}
>
  <span class="mr-2">{label}</span>
  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
  </svg>
</a>

<style>
  a:hover svg {
    transform: translateX(2px);
  }
  
  a:focus {
    outline: 2px solid #2563eb;
    outline-offset: 2px;
  }
</style>

<script>
  const links = document.querySelectorAll("[data-affiliate-tracker]");
  links.forEach((link) => {
    link.addEventListener("click", (e) => {
      const toolId = link.getAttribute("data-tool-id");
      const variant = link.getAttribute("data-variant") || 'primary';
      
      // Global event for analytics
      window.dispatchEvent(
        new CustomEvent("affiliate-click", {
          detail: { 
            toolId, 
            variant,
            timestamp: Date.now(),
            page: window.location.pathname
          }
        })
      );
      
      // Console tracking for development
      if (window.location.hostname === 'localhost') {
        console.log(`🔗 Affiliate click tracked: ${toolId} (${variant})`);
      }
    });
  });
</script>
