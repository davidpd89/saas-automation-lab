---
interface Props {
  url: string;
  label: string;
  toolId: string;
  variant?: "primary" | "secondary" | "outline";
  size?: "sm" | "md" | "lg";
  showDisclosure?: boolean;
}

const {
  url,
  label,
  toolId,
  variant = "primary",
  size = "md",
  showDisclosure = true
} = Astro.props;

const baseClasses = "affiliate-button";
const variantClasses = {
  primary: "affiliate-button-primary",
  secondary: "affiliate-button-secondary",
  outline: "affiliate-button-outline"
};
const sizeClasses = {
  sm: "affiliate-button-sm",
  md: "affiliate-button-md",
  lg: "affiliate-button-lg"
};
const classes = `${baseClasses} ${variantClasses[variant]} ${sizeClasses[size]}`;
---

{showDisclosure && (
  <div class="affiliate-disclosure">
    Puede ser afiliado. La recomendación se basa en encaje y pruebas, no en comisión.
  </div>
)}

<a
  href={url}
  class={classes}
  rel="sponsored nofollow"
  target="_blank"
  aria-label={`Abrir ${label} en pestaña nueva`}
  data-tool-id={toolId}
  data-variant={variant}
  data-affiliate-tracker="true"
>
  <span>{label}</span>
  <span aria-hidden="true">→</span>
</a>

<script>
  const links = document.querySelectorAll("[data-affiliate-tracker]");
  links.forEach((link) => {
    link.addEventListener("click", () => {
      const toolId = link.getAttribute("data-tool-id");
      const variant = link.getAttribute("data-variant") || "primary";

      window.dispatchEvent(
        new CustomEvent("affiliate-click", {
          detail: {
            toolId,
            variant,
            timestamp: Date.now(),
            page: window.location.pathname
          }
        })
      );
    });
  });
</script>
