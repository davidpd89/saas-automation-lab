---
import AffiliateButton from "./AffiliateButton.astro";

interface Props {
  title: string;
  description: string;
  rating: number;
  toolId: string;
  affiliateUrl: string;
  href: string;
}

const { title, description, rating, toolId, affiliateUrl, href } = Astro.props;
---

<article class="card">
  <h3><a href={href}>{title}</a></h3>
  <p>{description}</p>
  <p><strong>Veredicto:</strong> nota {rating}/10 según encaje, coste, curva, integraciones y riesgo operativo.</p>
  <AffiliateButton url={affiliateUrl} label="Ver límites y precio real" toolId={toolId} />
</article>
