---
interface Props {
  stepNumber: number;
  totalSteps: number;
  title: string;
  summary: string;
}

const { stepNumber, totalSteps, title, summary } = Astro.props;
---

<article class="card">
  <p><strong>Paso {stepNumber} de {totalSteps}</strong></p>
  <h3>{title}</h3>
  <p>{summary}</p>
</article>
