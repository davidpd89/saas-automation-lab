---
interface Row {
  tool: string;
  pricing: string;
  bestFor: string;
}

interface Props {
  rows?: Row[];
  toolsCompared?: string[];
}

const { rows, toolsCompared = [] } = Astro.props;
const tableRows = rows ?? toolsCompared.map((tool) => ({
  tool,
  pricing: "Consultar plan",
  bestFor: "Ver analisis"
}));
---

<div class="card">
  <table>
    <thead>
      <tr>
        <th>Herramienta</th>
        <th>Precio base</th>
        <th>Mejor para</th>
      </tr>
    </thead>
    <tbody>
      {
        tableRows.map((row) => (
          <tr>
            <td>{row.tool}</td>
            <td>{row.pricing}</td>
            <td>{row.bestFor}</td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>
