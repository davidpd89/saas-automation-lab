---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ComparisonTable from "../../components/ComparisonTable.astro";
import AffiliateButton from "../../components/AffiliateButton.astro";

export async function getStaticPaths() {
  const items = [
    ...(await getCollection("comparisons")),
    ...(await getCollection("comparativas"))
  ];
  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item }
  }));
}

const { item } = Astro.props;
const { Content } = await item.render();
const siteUrl = new URL(import.meta.env.BASE_URL, Astro.site ?? new URL("https://davidpd89.github.io")).toString();
const allTools = await getCollection("tools");
const comparedTools = allTools.filter((tool) => item.data.toolsCompared?.includes(tool.data.toolId));
const tableRows = comparedTools.map((tool) => ({
  tool: tool.data.title,
  pricing: tool.data.pricing,
  bestFor: tool.data.idealUser
}));

// Schema markup for comparison pages
const comparisonSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": item.data.title,
  "description": item.data.seoDescription,
  "author": {
    "@type": "Person",
    "name": "David Porto",
    "url": "https://github.com/davidpd89"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Automatización SaaS e IA",
    "url": siteUrl
  },
  "dateModified": new Date().toISOString(),
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": item.data.toolsCompared?.length || 3,
    "itemListElement": item.data.toolsCompared?.map((tool, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "SoftwareApplication",
        "name": tool
      }
    }))
  }
};
---

<BaseLayout title={item.data.seoTitle} description={item.data.seoDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(comparisonSchema)} />
  
  <article class="max-w-4xl mx-auto px-4 py-8">
    <header class="text-center mb-12">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">
        {item.data.title}
      </h1>
      
      <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-8">
        <h2 class="text-2xl font-semibold text-green-900 mb-2">🏆 Veredicto Rápido</h2>
        <p class="text-lg text-green-800 font-medium">
          {item.data.verdict}
        </p>
      </div>
    </header>

    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Comparativa Detallada</h2>
      <ComparisonTable rows={tableRows.length ? tableRows : undefined} toolsCompared={item.data.toolsCompared || []} />
    </section>

    {comparedTools.length > 0 && (
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Probar herramientas comparadas</h2>
        <div class="grid grid-3">
          {comparedTools.map((tool) => (
            <article class="card">
              <h3>{tool.data.title}</h3>
              <p>{tool.data.description}</p>
              <AffiliateButton
                url={tool.data.affiliateUrl}
                label="Ver herramienta"
                toolId={tool.data.toolId}
                variant="outline"
              />
            </article>
          ))}
        </div>
      </section>
    )}

    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Casos de Uso por Perfil</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-blue-50 p-6 rounded-lg">
          <h3 class="font-semibold text-blue-900 mb-3">👨‍💼 Consultor Técnico</h3>
          <p class="text-blue-800">
            Elige herramientas con control técnico y APIs abiertas para personalizaciones avanzadas.
          </p>
        </div>
        <div class="bg-green-50 p-6 rounded-lg">
          <h3 class="font-semibold text-green-900 mb-3">🎯 Coach</h3>
          <p class="text-green-800">
            Prioriza facilidad de uso y automatización de procesos repetitivos sin código.
          </p>
        </div>
        <div class="bg-purple-50 p-6 rounded-lg">
          <h3 class="font-semibold text-purple-900 mb-3">📚 Formador</h3>
          <p class="text-purple-800">
            Necesita plataformas LMS robustas y sistemas de entrega de contenido escalables.
          </p>
        </div>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Análisis de Costes Reales</h2>
      <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-6">
        <p class="text-yellow-800 mb-4">
          <strong>⚠️ Importante:</strong> Los costes mostrados son para volúmenes de uso realistas (1,000-10,000 operaciones/mes). 
          A mayor escala, los costes pueden variar significativamente.
        </p>
        <div class="grid md:grid-cols-2 gap-4 text-sm">
          <div>
            <strong>Make:</strong> Más económico a gran escala (€90-160 por 100K ops)
          </div>
          <div>
            <strong>Zapier:</strong> Más caro a gran escala (€2,500-6,000 por 100K tareas)
          </div>
          <div>
            <strong>n8n:</strong> Balance entre control y coste (€200-450 por 100K ejecuciones)
          </div>
        </div>
      </div>
    </section>

    <section class="prose prose-lg max-w-none mb-12">
      <Content />
    </section>

    <section class="bg-gray-50 rounded-lg p-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">🚀 Stack Recomendado</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-white p-6 rounded-lg border border-gray-200">
          <h3 class="font-semibold text-gray-900 mb-3">Para Principiantes</h3>
          <p class="text-gray-700 mb-4">
            Make → ConvertKit → Webflow
          </p>
          <p class="text-sm text-gray-600">
            Automatización visual + Email marketing + Web profesional
          </p>
        </div>
        <div class="bg-white p-6 rounded-lg border border-gray-200">
          <h3 class="font-semibold text-gray-900 mb-3">Para Técnicos</h3>
          <p class="text-gray-700 mb-4">
            n8n → Clientify → Thinkific
          </p>
          <p class="text-sm text-gray-600">
            Control total + WhatsApp nativo + LMS potente
          </p>
        </div>
      </div>
    </section>
  </article>
</BaseLayout>
