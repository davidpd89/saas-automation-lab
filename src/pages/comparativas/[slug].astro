---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ComparisonTable from "../../components/ComparisonTable.astro";
import AffiliateButton from "../../components/AffiliateButton.astro";
import StructuredData from "../../components/StructuredData.astro";

export async function getStaticPaths() {
  const items = [
    ...(await getCollection("comparisons")),
    ...(await getCollection("comparativas"))
  ];
  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item }
  }));
}

const { item } = Astro.props;
const { Content } = await item.render();
const siteUrl = new URL(import.meta.env.BASE_URL, Astro.site ?? new URL("https://davidpd89.github.io")).toString();
const allTools = await getCollection("tools");
const comparedTools = allTools.filter((tool) => item.data.toolsCompared?.includes(tool.data.toolId));
const tableRows = comparedTools.map((tool) => ({
  tool: tool.data.title,
  pricing: tool.data.pricing,
  bestFor: item.data.bestFor?.[tool.data.toolId] ?? tool.data.idealUser
}));
const criteria = item.data.decisionCriteria.length
  ? item.data.decisionCriteria
  : ["Coste real al escalar", "Curva de aprendizaje", "Control tecnico", "Integraciones", "Riesgo operativo"];

const comparisonSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": item.data.title,
  "description": item.data.seoDescription,
  "author": {
    "@type": "Person",
    "name": "David Porto",
    "url": "https://github.com/davidpd89"
  },
  "publisher": {
    "@type": "Organization",
    "name": "SaaS Automation Lab",
    "url": siteUrl
  },
  "dateModified": item.data.updatedAt?.toISOString() ?? new Date().toISOString(),
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": item.data.toolsCompared?.length || 3,
    "itemListElement": item.data.toolsCompared?.map((tool, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "SoftwareApplication",
        "name": tool
      }
    }))
  }
};
---

<BaseLayout title={item.data.seoTitle} description={item.data.seoDescription}>
  <StructuredData data={comparisonSchema} />

  <article class="max-w-4xl mx-auto px-4 py-8">
    <header class="text-center mb-12">
      <p class="eyebrow">Comparativa money</p>
      <h1 class="text-4xl font-bold text-gray-900 mb-4">{item.data.title}</h1>

      <div class="answer-box mb-8">
        <h2 class="text-2xl font-semibold text-green-900 mb-2">Veredicto rapido</h2>
        <p class="text-lg text-green-800 font-medium">{item.data.verdict}</p>
      </div>
    </header>

    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Comparativa detallada</h2>
      <ComparisonTable rows={tableRows.length ? tableRows : undefined} toolsCompared={item.data.toolsCompared || []} />
    </section>

    <section class="mb-12 grid grid-2">
      <article class="card">
        <h2>Criterios de decision</h2>
        <ul>
          {criteria.map((criterion) => <li>{criterion}</li>)}
        </ul>
      </article>
      <article class="card">
        <h2>Como leer esta comparativa</h2>
        <p>Primero decide perfil y volumen. Una herramienta barata al inicio puede salir cara si tus tareas, contactos o ejecuciones crecen rapido.</p>
      </article>
    </section>

    {comparedTools.length > 0 && (
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Probar herramientas comparadas</h2>
        <p class="trust-note">Disclosure: estos enlaces pueden ser afiliados. El veredicto se basa en encaje, coste y caso de uso.</p>
        <div class="grid grid-3">
          {comparedTools.map((tool) => (
            <article class="card">
              <h3>{tool.data.title}</h3>
              <p>{tool.data.description}</p>
              <AffiliateButton
                url={tool.data.affiliateUrl}
                label="Ver herramienta"
                toolId={tool.data.toolId}
                variant="outline"
              />
            </article>
          ))}
        </div>
      </section>
    )}

    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Veredicto por perfil</h2>
      <div class="grid grid-3">
        <div class="card">
          <h3>Consultor tecnico</h3>
          <p>Prioriza control, APIs, logs, exportacion y capacidad de depurar flujos complejos.</p>
        </div>
        <div class="card">
          <h3>Coach</h3>
          <p>Prioriza facilidad de uso, seguimiento, WhatsApp, recordatorios y experiencia de cliente.</p>
        </div>
        <div class="card">
          <h3>Formador</h3>
          <p>Prioriza email, LMS, entrega evergreen, analitica de alumnos y mantenimiento sencillo.</p>
        </div>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Coste real y limites</h2>
      <div class="notice">
        <p>
          <strong>Importante:</strong> Los costes son orientativos y deben validarse con la pagina oficial.
          Para volumen alto, compara coste por tarea, limites de plan y coste de mantenimiento.
        </p>
        <div class="grid grid-2 text-sm">
          <div><strong>Automatizacion visual:</strong> revisa operaciones, tareas premium y limites de historial.</div>
          <div><strong>Automatizacion tecnica:</strong> revisa servidor, logs, mantenimiento y responsabilidad operativa.</div>
          <div><strong>CRM/email:</strong> revisa contactos, envios, usuarios y coste de escalado.</div>
          <div><strong>IA/agentes:</strong> revisa coste por ejecucion, tokens, memoria y privacidad de datos.</div>
        </div>
      </div>
    </section>

    <section class="prose prose-lg max-w-none mb-12">
      <Content />
    </section>

    <section class="bg-gray-50 rounded-lg p-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Stack recomendado</h2>
      <div class="grid grid-2">
        <div class="card">
          <h3>Para empezar sin friccion</h3>
          <p>Make + ConvertKit + Webflow</p>
          <p class="text-sm text-gray-600">Automatizacion visual, email marketing y web profesional.</p>
        </div>
        <div class="card">
          <h3>Para control tecnico</h3>
          <p>n8n + Clientify + Thinkific</p>
          <p class="text-sm text-gray-600">Control de flujos, CRM con seguimiento y entrega formativa.</p>
        </div>
      </div>
    </section>
  </article>
</BaseLayout>
