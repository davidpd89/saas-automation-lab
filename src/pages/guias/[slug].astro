---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import GuideStep from "../../components/GuideStep.astro";

export async function getStaticPaths() {
  const items = await getCollection("guides");
  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item }
  }));
}

const { item } = Astro.props;
const { Content } = await item.render();
const tools = await getCollection("tools");
const usedTools = tools.filter((tool) => item.data.toolsUsed.includes(tool.data.toolId));
const withBase = (path = "") => `${import.meta.env.BASE_URL}${path.replace(/^\/+/, "")}`;
const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": item.data.title,
  "description": item.data.seoDescription,
  "tool": usedTools.map((tool) => ({
    "@type": "HowToTool",
    "name": tool.data.title
  })),
  "step": [
    { "@type": "HowToStep", "position": 1, "name": "Disenar formulario de alta" },
    { "@type": "HowToStep", "position": 2, "name": "Crear flujo n8n" },
    { "@type": "HowToStep", "position": 3, "name": "Notificar por WhatsApp y CRM" }
  ]
};
---

<BaseLayout title={item.data.seoTitle} description={item.data.seoDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
  <article>
    <h1>{item.data.title}</h1>
    <p><strong>Dificultad:</strong> {item.data.difficulty}</p>
    <p><strong>Persona:</strong> {item.data.persona}</p>
    <p><strong>Ahorro estimado:</strong> {item.data.timeSaved}</p>
  </article>

  <section class="grid">
    <GuideStep stepNumber={1} totalSteps={3} title="Disenar formulario de alta" summary="Define los campos que activan tu automatizacion." />
    <GuideStep stepNumber={2} totalSteps={3} title="Crear flujo n8n" summary="Conecta triggers, enrichment y asignacion de tareas." />
    <GuideStep stepNumber={3} totalSteps={3} title="Notificar por WhatsApp y CRM" summary="Entrega mensaje al cliente y crea su ficha comercial." />
  </section>

  {usedTools.length > 0 && (
    <section class="mt-12">
      <h2>Stack necesario</h2>
      <div class="grid grid-3">
        {usedTools.map((tool) => (
          <article class="card">
            <h3><a href={withBase(`herramientas/${tool.slug}/`)}>{tool.data.title}</a></h3>
            <p>{tool.data.description}</p>
            <p><strong>Precio:</strong> {tool.data.pricing}</p>
          </article>
        ))}
      </div>
    </section>
  )}

  <section class="prose-page">
    <Content />
  </section>
</BaseLayout>
