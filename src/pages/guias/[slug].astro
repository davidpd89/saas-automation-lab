---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import GuideStep from "../../components/GuideStep.astro";

export async function getStaticPaths() {
  const items = await getCollection("guides");
  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item }
  }));
}

const { item } = Astro.props;
---

<BaseLayout title={item.data.seoTitle} description={item.data.seoDescription}>
  <article>
    <h1>{item.data.title}</h1>
    <p><strong>Dificultad:</strong> {item.data.difficulty}</p>
    <p><strong>Persona:</strong> {item.data.persona}</p>
    <p><strong>Ahorro estimado:</strong> {item.data.timeSaved}</p>
  </article>

  <section class="grid">
    <GuideStep stepNumber={1} totalSteps={3} title="Disenar formulario de alta" summary="Define los campos que activan tu automatizacion." />
    <GuideStep stepNumber={2} totalSteps={3} title="Crear flujo n8n" summary="Conecta triggers, enrichment y asignacion de tareas." />
    <GuideStep stepNumber={3} totalSteps={3} title="Notificar por WhatsApp y CRM" summary="Entrega mensaje al cliente y crea su ficha comercial." />
  </section>
</BaseLayout>
