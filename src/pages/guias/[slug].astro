---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import GuideStep from "../../components/GuideStep.astro";
import StructuredData from "../../components/StructuredData.astro";
import MascotImage from "../../components/MascotImage.astro";

export async function getStaticPaths() {
  const items = await getCollection("guides");
  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item }
  }));
}

const { item } = Astro.props;
const { Content } = await item.render();
const tools = await getCollection("tools");
const usedTools = tools.filter((tool) => item.data.toolsUsed.includes(tool.data.toolId));
const withBase = (path = "") => `${import.meta.env.BASE_URL}${path.replace(/^\/+/, "")}`;
const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": item.data.title,
  "description": item.data.seoDescription,
  "tool": usedTools.map((tool) => ({
    "@type": "HowToTool",
    "name": tool.data.title
  })),
  "step": [
    { "@type": "HowToStep", "position": 1, "name": "Disenar formulario de alta" },
    { "@type": "HowToStep", "position": 2, "name": "Crear flujo n8n" },
    { "@type": "HowToStep", "position": 3, "name": "Notificar por WhatsApp y CRM" }
  ]
};
---

<BaseLayout title={item.data.seoTitle} description={item.data.seoDescription}>
  <StructuredData data={howToSchema} />
  <article class="prose-page">
    <p class="eyebrow">Guia de proceso</p>
    <h1>{item.data.title}</h1>
    <MascotImage
      type="guias"
      class="page-mascot"
      customAlt={`Ilustracion SEO de guia paso a paso: ${item.data.title}`}
    />
    <div class="answer-box">
      <strong>Respuesta breve:</strong> {item.data.expectedResult ?? `Este flujo busca ahorrar ${item.data.timeSaved} en un escenario de ${item.data.persona}.`}
    </div>
    <p><strong>Dificultad:</strong> {item.data.difficulty}</p>
    <p><strong>Persona:</strong> {item.data.persona}</p>
    <p><strong>Ahorro estimado:</strong> {item.data.timeSaved}</p>
    <p><strong>Escenario:</strong> {item.data.scenario}</p>
  </article>

  <section class="grid">
    <GuideStep stepNumber={1} totalSteps={3} title="Disenar formulario de alta" summary="Define los campos que activan tu automatizacion." />
    <GuideStep stepNumber={2} totalSteps={3} title="Crear flujo n8n" summary="Conecta triggers, enrichment y asignacion de tareas." />
    <GuideStep stepNumber={3} totalSteps={3} title="Notificar por WhatsApp y CRM" summary="Entrega mensaje al cliente y crea su ficha comercial." />
  </section>

  {usedTools.length > 0 && (
    <section class="mt-12">
      <h2>Stack necesario</h2>
      <div class="grid grid-3">
        {usedTools.map((tool) => (
          <article class="card">
            <h3><a href={withBase(`herramientas/${tool.slug}/`)}>{tool.data.title}</a></h3>
            <p>{tool.data.description}</p>
            <p><strong>Precio:</strong> {tool.data.pricing}</p>
          </article>
        ))}
      </div>
    </section>
  )}

  <section class="mt-12 grid grid-2">
    <article class="card">
      <h2>Errores frecuentes</h2>
      <ul>
        {(item.data.commonErrors.length ? item.data.commonErrors : ["Automatizar sin limpiar el proceso manual.", "No probar errores y casos limite.", "No medir ahorro real antes de anadir mas herramientas."]).map((error) => (
          <li>{error}</li>
        ))}
      </ul>
    </article>
    <article class="card">
      <h2>Resultado esperado</h2>
      <p>{item.data.expectedResult ?? "Un flujo documentado, medible y conectado con herramientas que puedas mantener sin depender de memoria manual."}</p>
    </article>
  </section>

  <section class="prose-page">
    <Content />
  </section>
</BaseLayout>
