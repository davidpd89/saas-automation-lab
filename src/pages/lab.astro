---
import { getCollection } from "astro:content";
import LabLayout from "../layouts/LabLayout.astro";

const pillars = await getCollection("pillars");
const item = pillars.find((entry) => entry.slug === "lab");

if (!item) {
  throw new Error("Missing lab pillar content");
}

const { Content } = await item.render();
---

<LabLayout frontmatter={item.data}>
  <Content />
</LabLayout>
