---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import AffiliateButton from "../../components/AffiliateButton.astro";

export async function getStaticPaths() {
  const items = await getCollection("tools");
  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item }
  }));
}

const { item } = Astro.props;
const { Content } = await item.render();
const siteUrl = new URL(import.meta.env.BASE_URL, Astro.site ?? new URL("https://davidpd89.github.io")).toString();

// Schema markup for tool pages
const toolSchema = {
  "@context": "https://schema.org",
  "@type": "Review",
  "itemReviewed": {
    "@type": "SoftwareApplication",
    "name": item.data.title,
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web Browser",
    "offers": {
      "@type": "Offer",
      "price": item.data.pricing,
      "priceCurrency": "EUR"
    }
  },
  "reviewRating": {
    "@type": "Rating",
    "ratingValue": item.data.rating,
    "bestRating": 10,
    "worstRating": 1
  },
  "author": {
    "@type": "Person",
    "name": "David Porto",
    "url": "https://github.com/davidpd89"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Automatización SaaS e IA",
    "url": siteUrl
  }
};
---

<BaseLayout title={item.data.seoTitle} description={item.data.seoDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(toolSchema)} />
  
  <article class="max-w-4xl mx-auto px-4 py-8">
    <header class="mb-8">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">
        {item.data.title}
      </h1>
      
      <div class="flex flex-wrap items-center gap-4 mb-6 text-sm text-gray-600">
        <span class="bg-blue-100 text-blue-800 px-3 py-1 rounded-full">
          {item.data.idealUser}
        </span>
        <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full">
          {item.data.pricing}
        </span>
        <span class="flex items-center">
          ⭐ {item.data.rating}/10
        </span>
      </div>
      
      <p class="text-xl text-gray-700 leading-relaxed">
        {item.data.description}
      </p>
    </header>

    <section class="mb-12">
      <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
        <h2 class="text-lg font-semibold text-blue-900 mb-4">Para quién es esta herramienta</h2>
        <p class="text-blue-800">
          Ideal para <strong>{item.data.idealUser}</strong> que necesita automatizar procesos y escalar su negocio sin aumentar el tiempo manual.
        </p>
        
        <div class="mt-6">
          <AffiliateButton 
            url={item.data.affiliateUrl} 
            label="Probar gratis" 
            toolId={item.data.toolId}
            variant="primary"
            size="lg"
            showDisclosure={true}
          />
        </div>
      </div>
    </section>

    <section class="prose prose-lg max-w-none">
      <Content />
    </section>

    {item.data.affiliate && (
      <section class="mt-12 p-6 bg-gray-50 rounded-lg">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Información de Afiliación</h2>
        <div class="grid md:grid-cols-2 gap-4 text-sm">
          <div>
            <strong>Comisión:</strong> {item.data.affiliate.commissionRange}
          </div>
          <div>
            <strong>Tipo:</strong> {item.data.affiliate.commissionType}
          </div>
          <div>
            <strong>Cookie:</strong> {item.data.affiliate.cookieDays} días
          </div>
          <div>
            <strong>Plataforma:</strong> {item.data.affiliate.platform}
          </div>
        </div>
      </section>
    )}
  </article>
</BaseLayout>
