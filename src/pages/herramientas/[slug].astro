---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import AffiliateButton from "../../components/AffiliateButton.astro";
import StructuredData from "../../components/StructuredData.astro";
import MascotImage from "../../components/MascotImage.astro";

export async function getStaticPaths() {
  const items = await getCollection("tools");
  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item }
  }));
}

const { item } = Astro.props;
const { Content } = await item.render();
const siteUrl = new URL(import.meta.env.BASE_URL, Astro.site ?? new URL("https://davidpd89.github.io")).toString();
const faqItems = [
  {
    question: `Para quien es ${item.data.title}?`,
    answer: item.data.description
  },
  {
    question: `Cuanto cuesta ${item.data.title}?`,
    answer: `El precio de referencia es ${item.data.pricing}. Verifica siempre la pagina oficial antes de contratar.`
  },
  {
    question: "Esta recomendacion incluye enlaces de afiliado?",
    answer: "Si. Algunos enlaces pueden generar una comision sin coste adicional para el lector, pero la comision no compra posiciones ni veredictos."
  }
];

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": item.data.title,
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Web Browser",
  "description": item.data.description,
  "offers": {
    "@type": "Offer",
    "price": item.data.pricing,
    "priceCurrency": "EUR"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": item.data.rating,
    "bestRating": 10,
    "worstRating": 1,
    "ratingCount": 1
  }
};

const toolSchema = {
  "@context": "https://schema.org",
  "@type": "Review",
  "itemReviewed": {
    "@type": "SoftwareApplication",
    "name": item.data.title,
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web Browser",
    "offers": {
      "@type": "Offer",
      "price": item.data.pricing,
      "priceCurrency": "EUR"
    }
  },
  "reviewRating": {
    "@type": "Rating",
    "ratingValue": item.data.rating,
    "bestRating": 10,
    "worstRating": 1
  },
  "author": {
    "@type": "Person",
    "name": "David Porto",
    "url": "https://github.com/davidpd89"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Automatiza Sin Humo",
    "url": siteUrl
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map((faq) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
---

<BaseLayout title={item.data.seoTitle} description={item.data.seoDescription}>
  <StructuredData data={[softwareSchema, toolSchema, faqSchema]} />

  <article class="max-w-4xl mx-auto px-4 py-8">
    <header class="mb-8">
      <p class="eyebrow">Ficha de herramienta</p>
      <h1 class="text-4xl font-bold text-gray-900 mb-4">{item.data.title}</h1>
      <MascotImage
        type="herramientas"
        class="page-mascot"
        customAlt={`Analisis y opiniones de ${item.data.title} para automatizacion IA y SaaS`}
      />

      <div class="flex flex-wrap items-center gap-4 mb-6 text-sm text-gray-600">
        <span class="bg-blue-100 text-blue-800 px-3 py-1 rounded-full">
          {item.data.idealUser}
        </span>
        <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full">
          {item.data.pricing}
        </span>
        <span class="flex items-center">
          Nota {item.data.rating}/10
        </span>
      </div>

      <p class="text-xl text-gray-700 leading-relaxed">
        {item.data.description}
      </p>
      <div class="answer-box">
        <strong>Respuesta breve:</strong> {item.data.title} encaja si resuelve un proceso concreto para {item.data.idealUser}. No la elegiria sin validar precio, limites, curva y alternativa directa.
      </div>
    </header>

    <section class="mb-12">
      <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
        <h2 class="text-lg font-semibold text-blue-900 mb-4">Para quien es esta herramienta</h2>
        <p class="text-blue-800">
          Encaja mejor con <strong>{item.data.idealUser}</strong> si el proceso ya esta definido y necesitas reducir tareas manuales sin perder trazabilidad.
        </p>
        <p class="trust-note">Disclosure: este CTA puede ser afiliado. La recomendacion no depende de la comision.</p>

        <div class="mt-6">
          <AffiliateButton
            url={item.data.affiliateUrl}
            label="Cuando elegirla"
            toolId={item.data.toolId}
            variant="primary"
            size="lg"
            showDisclosure={true}
          />
        </div>
      </div>
    </section>

    <section class="prose prose-lg max-w-none">
      <Content />
    </section>

    <section class="mt-12 grid grid-2">
      <article class="card">
        <h2>Que hemos podido comprobar</h2>
        <ul>
          {(item.data.pros.length ? item.data.pros : ["Buen encaje si resuelve el caso de uso principal.", "Puede integrarse en stacks de automatizacion.", "Permite comparar coste frente a trabajo manual."]).map((pro) => (
            <li>{pro}</li>
          ))}
        </ul>
      </article>
      <article class="card">
        <h2>Contras y riesgos</h2>
        <ul>
          {(item.data.cons.length ? item.data.cons : ["Precios y limites pueden cambiar.", "Requiere validar integraciones antes de depender de ella.", "No sustituye una metodologia clara de procesos."]).map((con) => (
            <li>{con}</li>
          ))}
        </ul>
      </article>
    </section>

    <section class="mt-12 p-6 bg-gray-50 rounded-lg border">
      <p class="eyebrow">Metodo de evaluacion</p>
      <h2>Como evaluamos esta herramienta</h2>
      <p>
        Revisamos encaje por perfil, claridad de precios, integraciones, curva de aprendizaje,
        transparencia del programa de afiliados y utilidad real para negocios de servicios.
      </p>
      <dl class="definition-list">
        <dt>Prueba minima</dt>
        <dd>{item.data.evidence[0] ?? "Flujo o escenario documentado antes de elevarla a recomendacion principal."}</dd>
        <dt>Criterio clave</dt>
        <dd>{item.data.methodology[0] ?? "Coste, control, facilidad de implementacion y riesgo operativo."}</dd>
      </dl>
    </section>

    {item.data.affiliate && (
      <section class="mt-12 p-6 bg-gray-50 rounded-lg">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Informacion de afiliacion</h2>
        <div class="grid md:grid-cols-2 gap-4 text-sm">
          <div>
            <strong>Comision:</strong> {item.data.affiliate.commissionRange}
          </div>
          <div>
            <strong>Tipo:</strong> {item.data.affiliate.commissionType}
          </div>
          <div>
            <strong>Cookie:</strong> {item.data.affiliate.cookieDays} dias
          </div>
          <div>
            <strong>Plataforma:</strong> {item.data.affiliate.platform}
          </div>
        </div>
      </section>
    )}

    <section class="mt-12 p-6 bg-white rounded-lg border">
      <h2>Preguntas frecuentes</h2>
      {faqItems.map((faq) => (
        <details>
          <summary>{faq.question}</summary>
          <p>{faq.answer}</p>
        </details>
      ))}
    </section>
  </article>
</BaseLayout>
