---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const guides = await getCollection("guides");
const pillars = await getCollection("pillars");
const posts = [...pillars, ...guides];
const withBase = (path = "") => `${import.meta.env.BASE_URL}${path.replace(/^\/+/, "")}`;
const staticPosts = [
  {
    eyebrow: "Privacidad",
    title: "AI Act, RGPD y automatizacion comercial",
    description: "Checklist minima para publicar guias de automatizacion con datos personales, IA y lead scoring.",
    href: withBase("ai-act-rgpd-automatizacion/")
  },
  {
    eyebrow: "GEO",
    title: "Share of Model Voice",
    description: "Metodo para medir si ChatGPT, Claude, Perplexity y Gemini citan Automatiza Sin Humo.",
    href: withBase("share-of-model-voice/")
  }
];
---

<BaseLayout
  title="Blog de sistemas, SEO e IA para solopreneurs"
  description="Ideas y guias para escalar negocios de servicios con automatizacion, IA, contenido SEO y sistemas operativos ligeros."
>
  <section class="section-header">
    <p class="eyebrow">Fundamentos</p>
    <h1>Estrategias de escalado y sistemas para solopreneurs</h1>
    <p class="lede">Contenido informacional que sostiene las comparativas y guias transaccionales del laboratorio.</p>
  </section>

  <section class="grid grid-2">
    {staticPosts.map((post) => (
      <article class="card">
        <p class="eyebrow">{post.eyebrow}</p>
        <h2><a href={post.href}>{post.title}</a></h2>
        <p>{post.description}</p>
      </article>
    ))}
    {posts.map((entry) => {
      const collectionPath = entry.collection === "guides" ? "guias" : entry.slug === "lab" ? "lab" : entry.slug;
      const href = entry.collection === "guides"
        ? withBase(`${collectionPath}/${entry.slug}/`)
        : withBase(`${collectionPath}/`);

      return (
        <article class="card">
          <p class="eyebrow">{entry.collection}</p>
          <h2><a href={href}>{entry.data.title}</a></h2>
          <p>{entry.data.seoDescription ?? entry.data.description}</p>
        </article>
      );
    })}
  </section>
</BaseLayout>
