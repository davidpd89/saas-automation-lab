---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ToolCard from "../components/ToolCard.astro";

const tools = await getCollection("tools");
const withBase = (path = "") => `${import.meta.env.BASE_URL}${path.replace(/^\/+/, "")}`;
---

<BaseLayout
  title="Automatizacion SaaS e IA para Solopreneurs"
  description="Comparativas y guias para elegir herramientas SaaS con enfoque real en conversion y ahorro de tiempo."
>
  <section>
    <h1>Automatizacion SaaS e IA para Solopreneurs</h1>
    <p>
      Proyecto editorial y tecnico para ayudarte a elegir herramientas de automatizacion, CRM y marketing
      con criterio practico y enfoque de negocio.
    </p>
    <p>
      <a class="btn btn-primary" href={withBase("automatizacion-solopreneurs-2026/")}>Ver pagina pilar principal</a>
      <a class="btn" href={withBase("escalar-negocio-servicios-ia/")}>Escalar con IA</a>
      <a class="btn" href={withBase("automatizacion-facturacion-cobros-consultores/")}>Facturacion automatizada</a>
    </p>
  </section>

  <section class="grid grid-3">
    <article class="card">
      <p class="eyebrow">Coach</p>
      <h2>Onboarding y seguimiento</h2>
      <p>Webflow, Clientify y n8n para entregar accesos, mensajes y seguimiento sin trabajo manual.</p>
    </article>
    <article class="card">
      <p class="eyebrow">Formador</p>
      <h2>Evergreen y contenido</h2>
      <p>Thinkific, ConvertKit y Blym para atraer trafico, nutrir leads y entregar formacion.</p>
    </article>
    <article class="card">
      <p class="eyebrow">Consultor B2B</p>
      <h2>Prospeccion y cierre</h2>
      <p>lemlist, Make y Clientify para convertir outbound y propuestas en un proceso repetible.</p>
    </article>
  </section>

  <section>
    <h2>Herramientas destacadas</h2>
    <div class="grid grid-3">
      {
        tools.map(({ data, slug }) => (
          <ToolCard
            title={data.title}
            description={data.description}
            rating={data.rating}
            toolId={data.toolId}
            affiliateUrl={data.affiliateUrl}
            href={withBase(`herramientas/${slug}/`)}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
