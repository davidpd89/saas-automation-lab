---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ToolCard from "../components/ToolCard.astro";
import MascotImage from "../components/MascotImage.astro";
import DiagnosticChat from "../components/DiagnosticChat.astro";
import RoiCalculator from "../components/RoiCalculator.astro";

const tools = await getCollection("tools");
const withBase = (path = "") => `${import.meta.env.BASE_URL}${path.replace(/^\/+/, "")}`;
// Make primero (afiliado activo con promo), luego herramientas nucleares
const featuredOrder = ["make-com", "n8n-cloud", "clientify", "lemlist", "thinkific", "convertkit"];
const featuredTools = featuredOrder
  .map((id) => tools.find(({ data }) => data.toolId === id))
  .filter(Boolean);
---

<BaseLayout
  title="Automatización SaaS e IA para negocios de servicios"
  description="Diagnóstico, comparativas y guías para elegir herramientas SaaS con foco en workflows reales, coste y ahorro de tiempo."
>
  <section class="hero-panel hero-split">
    <div>
      <p class="eyebrow">Flujos reales, costes claros y decisiones con criterio</p>
      <h1>Automatiza tu negocio de servicios con un stack que puedas mantener</h1>
      <p>
        Probamos herramientas SaaS e IA con workflows reales de captación, onboarding, CRM,
        email y seguimiento para que elijas sin perder semanas comparando.
      </p>
      <p class="trust-note">
        La comisión no decide el ranking. Cada recomendación debe tener caso de uso,
        límites, coste estimado y alternativa.
      </p>
      <p class="cta-row">
        <a class="btn btn-primary" href={withBase("automatizacion-solopreneurs-2026/")}>Empezar por el mapa del stack</a>
        <a class="btn btn-secondary" href={withBase("lab/")}>Ver como probamos</a>
        <a class="btn btn-secondary" href={withBase("ai-act-rgpd-automatizacion/")}>Ver checklist AI Act/RGPD</a>
      </p>
    </div>
    <MascotImage
      type="home"
      loading="eager"
      priority={true}
      class="hero-mascot"
      customAlt="Laboratorio visual de automatizacion SaaS e IA para ordenar workflows de negocios de servicios"
    />
  </section>

  <DiagnosticChat />

  <RoiCalculator compact={true} />

  <section class="grid grid-3">
    <article class="card">
      <p class="eyebrow">Coach</p>
      <h2>Onboarding y seguimiento</h2>
      <MascotImage
        type="coach"
        class="card-visual"
        width={360}
        customAlt="Coach usando automatizacion para onboarding seguimiento y experiencia de cliente"
      />
      <p>Después de cada venta: acceso, bienvenida, ficha en CRM y primer seguimiento sin perseguir mensajes en WhatsApp.</p>
      <a class="text-link" href={withBase("guias/onboarding-automatizado-n8n-whatsapp/")}>Ver flujo de onboarding</a>
    </article>
    <article class="card">
      <p class="eyebrow">Formador</p>
      <h2>Evergreen y contenido</h2>
      <MascotImage
        type="formador"
        class="card-visual"
        width={360}
        customAlt="Formador conectando cursos email marketing y automatizacion evergreen"
      />
      <p>Convierte formulario, email y plataforma de cursos en un sistema evergreen medible.</p>
      <a class="text-link" href={withBase("comparativas/convertkit-vs-mailerlite/")}>Comparar email marketing</a>
    </article>
    <article class="card">
      <p class="eyebrow">Consultor B2B</p>
      <h2>Prospeccion y cierre</h2>
      <MascotImage
        type="consultor"
        class="card-visual"
        width={360}
        customAlt="Consultor B2B organizando prospeccion CRM y seguimiento automatizado"
      />
      <p>Convierte leads, propuestas y seguimientos en un pipeline que no dependa de tu memoria.</p>
      <a class="text-link" href={withBase("guias/prospeccion-automatizada-lemlist/")}>Ver flujo outbound</a>
    </article>
  </section>

  <section>
    <div class="section-header">
      <p class="eyebrow">Primeras decisiones</p>
      <h2>Elige el punto de entrada según tu bloqueo</h2>
      <p class="lede">No hace falta leerlo todo: entra por problema, por comparativa o por metodología.</p>
    </div>
    <div class="grid grid-3">
      <article class="card card-accent">
        <h3>Quiero escalar servicios con IA</h3>
        <p>Mapa de procesos para crecer sin contratar antes de tiempo.</p>
        <a class="btn btn-secondary" href={withBase("escalar-negocio-servicios-ia/")}>Ver pilar</a>
      </article>
      <article class="card card-accent">
        <h3>Quiero elegir entre n8n, Make y Zapier</h3>
        <p>Comparativa troncal para coste, control técnico y curva de aprendizaje.</p>
        <a class="btn btn-secondary" href={withBase("comparativas/n8n-vs-make-vs-zapier/")}>Comparar opciones</a>
      </article>
      <article class="card card-accent">
        <h3>Quiero automatizar cobros</h3>
        <p>Arquitectura para facturas, recordatorios y seguimiento de morosidad.</p>
        <a class="btn btn-secondary" href={withBase("automatizacion-facturacion-cobros-consultores/")}>Ver sistema</a>
      </article>
    </div>
  </section>

  <section>
    <div class="section-header">
      <p class="eyebrow">Herramientas nucleares</p>
      <h2>Software que aparece una y otra vez en los workflows</h2>
      <p class="lede">El directorio completo existe, pero estas son las piezas que más conectan con automatización de servicios.</p>
    </div>
    <div class="notice" style="margin-bottom:1.5rem;">
      <strong>Promo activa en Make:</strong> Regístrate con el enlace de Automatiza Sin Humo y recibe <strong>1 mes del plan Pro con 10.000 operaciones gratis</strong>.
      <a class="text-link" href="https://www.make.com/en/register?pc=automatizasinhumo" rel="sponsored nofollow" target="_blank">Activar promo Make →</a>
    </div>
    <div class="grid grid-3">
      {
        featuredTools.map(({ data, slug }) => (
          <ToolCard
            title={data.title}
            description={data.description}
            rating={data.rating}
            toolId={data.toolId}
            affiliateUrl={data.affiliateUrl}
            href={withBase(`herramientas/${slug}/`)}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
